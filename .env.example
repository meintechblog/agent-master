# agent-master environment variables
# All are optional — defaults shown.
# Copy to .env if you use a dotenv loader, or set in your shell / LaunchAgent.

# Server
AGENT_HUB_PORT=7890                              # Port the HTTP server binds to
CLAUDE_PEERS_BROKER=http://localhost:7899        # Where the claude-peers broker runs

# Installer
AGENT_MASTER_DIR=$HOME/codex/agent-master        # Where install.sh clones the repo
AGENT_MASTER_REPO=https://github.com/meintechblog/agent-master.git  # Git remote to clone from
AGENT_HUB_LABEL=com.$USER.agent-hub              # macOS LaunchAgent label (and plist filename)
